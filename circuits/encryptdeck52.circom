    M[47][1] = 1131369846817699207467818622880768934338418324444440514270575019143804497556;
    M[48][0] = 17386594504742987867709199123940407114622143705013582123660965311449576087929;
    M[48][1] = 18113587164943529748713407182041752517206199217036590240803925021519989813919;
    M[49][0] = 11393356614877405198783044711998043631351342484007264997044462092350229714918;
    M[49][1] = 1631837355907549512185575692623734065168076198409170995312890152453556756195;
    M[50][0] = 16257260290674454725761605597495173678803471245971702030005143987297548407836;
    M[50][1] = 19324440445494438304803192194926088559108677137860844023409937395360117447211;
    M[51][0] = 3673082978401597800140653084819666873666278094336864183112751111018951461681;
    M[51][1] = 10697893536345518169195506678379072491856429121764117391188549778575809310354;

    component rBits[52];
    component c1Mul[52];
    component pkMul[52];
    component addC2[52];
    component cardCommit[52];
    component fold[52];

    signal computedC1[52][2];
    signal computedC2[52][2];
    signal cardCommits[52];
    signal runningCommit[53];

    for (var i = 0; i < 52; i++) {
        // r_i as 253 bits
        rBits[i] = Num2Bits(253);
        rBits[i].in <== r[i];

        // c1_i = r_i * BASE8
        c1Mul[i] = EscalarMulFix(253, BASE8);
        for (var j = 0; j < 253; j++) {
            c1Mul[i].e[j] <== rBits[i].out[j];
        }

        computedC1[i][0] <== c1Mul[i].out[0];
        computedC1[i][1] <== c1Mul[i].out[1];

        // r_i * pk
        pkMul[i] = EscalarMulAny(253);
        pkMul[i].p[0] <== pk[0];
        pkMul[i].p[1] <== pk[1];

        for (var j = 0; j < 253; j++) {
            pkMul[i].e[j] <== rBits[i].out[j];
        }

        // c2_i = M_i + r_i * pk
        addC2[i] = BabyAdd();
        addC2[i].x1 <== M[i][0];
        addC2[i].y1 <== M[i][1];
        addC2[i].x2 <== pkMul[i].out[0];
        addC2[i].y2 <== pkMul[i].out[1];

        computedC2[i][0] <== addC2[i].xout;
        computedC2[i][1] <== addC2[i].yout;

        // cardCommit_i = Poseidon4(c1.x, c1.y, c2.x, c2.y)
        cardCommit[i] = Poseidon(4);
        cardCommit[i].inputs[0] <== computedC1[i][0];
        cardCommit[i].inputs[1] <== computedC1[i][1];
        cardCommit[i].inputs[2] <== computedC2[i][0];
        cardCommit[i].inputs[3] <== computedC2[i][1];

        cardCommits[i] <== cardCommit[i].out;
    }

    // Fold all card commitments into one ordered deck commitment.
    runningCommit[0] <== 0;

    for (var i = 0; i < 52; i++) {
        fold[i] = Poseidon(2);
        fold[i].inputs[0] <== runningCommit[i];
        fold[i].inputs[1] <== cardCommits[i];
        runningCommit[i + 1] <== fold[i].out;
    }

    runningCommit[52] === outputDeckCommit;
}

component main {public [pk, outputDeckCommit]} = EncryptDeck52();
